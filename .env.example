# Postgres (pipeline_runs + gold layer; Airflow uses a separate `airflow` db here too)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retailrocket
POSTGRES_USER=retail
POSTGRES_PASSWORD=retail

# gold schema dbt writes into / the API reads from
GOLD_SCHEMA=gold

# Airflow
AIRFLOW_SECRET_KEY=retailrocket-dev

# Grafana admin login
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# webhook for Airflow task-failure alerts (Slack/Discord). Leave blank to disable.
ALERT_WEBHOOK_URL=
